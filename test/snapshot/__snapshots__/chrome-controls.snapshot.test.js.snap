// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`snapshot — chrome controls > after setNowPlaying + setPlayingState(true) — Pause button + label 1`] = `"<div class="hwes-controls"><div class="hwes-controls__now-playing">Track 3 of 12 — Holding On</div><div class="hwes-controls__progress-row"><span class="hwes-controls__time hwes-controls__time--start">0:00</span><div class="hwes-controls__progress" role="slider" tabindex="0" aria-label="Seek" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"><div class="hwes-controls__progress-fill"></div></div><span class="hwes-controls__time hwes-controls__time--end">0:00</span></div><div class="hwes-controls__buttons"><button type="button" class="hwes-controls__btn hwes-controls__btn--primary" aria-label="Pause">Pause</button><button type="button" class="hwes-controls__btn" aria-label="Skip to next item">Skip</button><button type="button" class="hwes-controls__btn hwes-controls__btn--skip-intro" aria-label="Skip the intro narration" style="display: none;">Skip Intro</button></div><div class="hwes-controls__volume-row"><span class="hwes-controls__volume-label">Vol</span><input type="range" class="hwes-controls__volume" min="0" max="1" step="0.01" aria-label="Volume"></div></div>"`;

exports[`snapshot — chrome controls > initial state — Play button + empty now-playing 1`] = `"<div class="hwes-controls"><div class="hwes-controls__now-playing">—</div><div class="hwes-controls__progress-row"><span class="hwes-controls__time hwes-controls__time--start">0:00</span><div class="hwes-controls__progress" role="slider" tabindex="0" aria-label="Seek" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"><div class="hwes-controls__progress-fill"></div></div><span class="hwes-controls__time hwes-controls__time--end">0:00</span></div><div class="hwes-controls__buttons"><button type="button" class="hwes-controls__btn hwes-controls__btn--primary" aria-label="Play">Play</button><button type="button" class="hwes-controls__btn" aria-label="Skip to next item">Skip</button><button type="button" class="hwes-controls__btn hwes-controls__btn--skip-intro" aria-label="Skip the intro narration" style="display: none;">Skip Intro</button></div><div class="hwes-controls__volume-row"><span class="hwes-controls__volume-label">Vol</span><input type="range" class="hwes-controls__volume" min="0" max="1" step="0.01" aria-label="Volume"></div></div>"`;
