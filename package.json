{
  "name": "@harmonic-wave/universal-player",
  "version": "0.0.1",
  "description": "Open-source HWES v1 reference implementation. Modular, recipe-driven, theme-aware player.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "sync-registry": "scripts/sync-registry.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:snapshot": "vitest run test/snapshot",
    "test:conformance": "vitest run test/conformance",
    "test:ci": "vitest run test/ci",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{src,test}/**/*.{js,json}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"{src,test}/**/*.{js,json}\" \"*.{json,md}\"",
    "verify:readme": "bun scripts/verify-readme.js",
    "dev": "python3 -m http.server 8080 --directory src",
    "ci:registry-drift": "vitest run test/ci/registry-sync.test.js"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=20"
  }
}
